import random
import tkinter as tk
from tkinter import messagebox

# --- 1. LOGIC ---
class User:
    def __init__(self, name, initial_balance=2000):
        self.name = name
        self.balance = initial_balance

    def deposit(self, amount):
        self.balance += amount
        
    def withdraw(self, amount):
        if self.balance >= amount:
            self.balance -= amount
            return True
        return False

# --- 2. THE MAIN CONTROLLER ---
class SwiftPayApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("SwiftPay Mobile")
        self.geometry("400x700")
        self.configure(bg="#121212")
        
        self.user = User(name="Alice")
        
        self.container = tk.Frame(self)
        self.container.pack(side="top", fill="both", expand=True)
        self.container.grid_rowconfigure(0, weight=1)
        self.container.grid_columnconfigure(0, weight=1)

        self.frames = {}
        for F in (LoginPage, DashboardPage):
            page_name = F.__name__
            frame = F(parent=self.container, controller=self)
            self.frames[page_name] = frame
            frame.grid(row=0, column=0, sticky="nsew")

        self.show_frame("LoginPage")

    def show_frame(self, page_name):
        frame = self.frames[page_name]
        frame.tkraise()

# --- 3. LOGIN PAGE ---
class LoginPage(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent, bg="#121212")
        self.controller = controller

        tk.Label(self, text="SwiftPay", fg="#00D084", bg="#121212", font=("Helvetica", 40, "bold")).pack(pady=(100, 10))
        tk.Label(self, text="Enter PIN to continue", fg="#666", bg="#121212").pack()
        
        self.pin_entry = tk.Entry(self, show="●", justify="center", font=("Helvetica", 30), bg="#1E1E1E", fg="white", bd=0, insertbackground="white")
        self.pin_entry.pack(pady=30, padx=60, ipady=10)
        self.pin_entry.insert(0, "1234")

        # Styled Login Button
        btn = tk.Frame(self, bg="#00D084", cursor="hand2")
        btn.pack(pady=20, padx=80, fill="x")
        lbl = tk.Label(btn, text="LOG IN", fg="black", bg="#00D084", font=("Helvetica", 12, "bold"), pady=15)
        lbl.pack()
        btn.bind("<Button-1>", lambda e: self.check_login())
        lbl.bind("<Button-1>", lambda e: self.check_login())

    def check_login(self):
        if self.pin_entry.get() == "1234":
            self.controller.show_frame("DashboardPage")
        else:
            messagebox.showerror("Error", "Try PIN: 1234")

# --- 4. DASHBOARD PAGE (The New Code You Asked About) ---
class DashboardPage(tk.Frame):
    def __init__(self, parent, controller):
        super().__init__(parent, bg="#121212")
        self.controller = controller
        self.user = controller.user

        # Header
        tk.Label(self, text=f"Welcome back, {self.user.name}", fg="#888", bg="#121212", font=("Helvetica", 10)).pack(pady=(20, 0))

        # Balance Card
        self.card = tk.Frame(self, bg="#1E1E1E", padx=20, pady=25, highlightthickness=1, highlightbackground="#333")
        self.card.pack(padx=25, pady=15, fill="x")
        
        tk.Label(self.card, text="AVAILABLE TO CASH OUT", fg="#00D084", bg="#1E1E1E", font=("Helvetica", 8, "bold")).pack()
        self.balance_var = tk.StringVar(value=f"${self.user.balance:,.2f}")
        self.lbl_balance = tk.Label(self.card, textvariable=self.balance_var, fg="white", bg="#1E1E1E", font=("Helvetica", 32, "bold"))
        self.lbl_balance.pack()

        # Amount Input
        tk.Label(self, text="Set Transaction Amount", fg="#AAA", bg="#121212", font=("Helvetica", 9, "bold")).pack(pady=(5, 5))
        self.amount_entry = tk.Entry(self, justify="center", font=("Helvetica", 20), bg="#000", fg="#00D084", borderwidth=0, insertbackground="white")
        self.amount_entry.insert(0, "100")
        self.amount_entry.pack(pady=5, padx=60, ipady=8)

        # Action Buttons
        self.create_modern_btn("Transfer to Bank", "#7042F4", self.do_loan)
        self.create_modern_btn("Buy Now, Pay Later", "#333333", self.do_bnpl)
        self.create_modern_btn("Instant Gamble", "#FF4500", self.do_gamble)

        # Transaction History Section
        tk.Label(self, text="RECENT ACTIVITY", fg="#555", bg="#121212", font=("Helvetica", 8, "bold")).pack(pady=(20, 5))
        self.history_frame = tk.Frame(self, bg="#181818", height=150)
        self.history_frame.pack(fill="both", padx=25, pady=5, expand=True)
        
        self.history_list = tk.Listbox(self.history_frame, bg="#181818", fg="#EEE", borderwidth=0, 
                                       highlightthickness=0, font=("Helvetica", 10), selectbackground="#181818")
        self.history_list.pack(fill="both", expand=True, padx=10, pady=10)

        # Sign Out
        tk.Button(self, text="Secure Sign Out", command=lambda: controller.show_frame("LoginPage"), 
                  bg="#121212", fg="#444", bd=0, font=("Helvetica", 9, "underline")).pack(side="bottom", pady=10)

    def create_modern_btn(self, text, color, cmd):
        f = tk.Frame(self, bg=color, cursor="hand2")
        f.pack(pady=6, padx=40, fill="x")
        l = tk.Label(f, text=text, fg="white", bg=color, font=("Helvetica", 11, "bold"), pady=12)
        l.pack()
        
        # Hover effects
        f.bind("<Enter>", lambda e: f.config(bg="#444") if color == "#333333" else None)
        f.bind("<Leave>", lambda e: f.config(bg=color))
        
        f.bind("<Button-1>", lambda e: cmd())
        l.bind("<Button-1>", lambda e: cmd())

    def log_transaction(self, message, is_positive=True):
        symbol = "+" if is_positive else "-"
        color = "#00D084" if is_positive else "#FF4500"
        self.history_list.insert(0, f"{message}")
        self.history_list.itemconfig(0, fg=color)

    def update_ui(self):
        self.balance_var.set(f"${self.user.balance:,.2f}")
        # Change balance color if low
        if self.user.balance < 500:
            self.lbl_balance.config(fg="#FF4500")
        else:
            self.lbl_balance.config(fg="white")

    def get_val(self):
        try:
            return float(self.amount_entry.get())
        except:
            messagebox.showwarning("Error", "Enter a valid amount")
            return None

    def do_loan(self):
        amt = self.get_val()
        if amt:
            self.user.deposit(amt)
            self.update_ui()
            self.log_transaction(f"Deposited: ${amt:,.2f}", True)

    def do_bnpl(self):
        amt = self.get_val()
        if amt and self.user.withdraw(amt/4):
            self.update_ui()
            self.log_transaction(f"BNPL Payment: ${amt/4:,.2f}", False)

    def do_gamble(self):
        amt = self.get_val()
        if amt and self.user.withdraw(amt):
            if random.random() > 0.5:
                self.user.deposit(amt * 2)
                self.log_transaction(f"Gamble Win: ${amt:,.2f}", True)
            else:
                self.log_transaction(f"Gamble Loss: ${amt:,.2f}", False)
            self.update_ui()

# --- 5. RUN ---
if __name__ == "__main__":
    app = SwiftPayApp()
    app.mainloop()
